import QtQuick 2.15
import QtQuick.Controls 2.15

Rectangle {
	width: Screen.width
	height: Screen.height

	//variables
	property color textColor: "#ffc6c6c6"
	property color placeHolderTextColor: "#ff525252"
	property color fieldBackgroundColor: "#ff242424"
	property color fieldBorderColor: "#ff525252"

	Image {
		anchors.fill: parent
		source: "Reactor.jpg"
		fillMode: Image.PreseverAspectCrop
	}

	// clock
	Text {
		id: clockText
		anchors.horizontalCenter: parent.horizontalCenter
		anchors.verticalCenter: parent.verticalCenter
		anchors.verticalCenterOffset: -250

		font.pixelSize: 130
		font.bold: true
		color: textColor

		text: Qt.formatTime(new Date(), "hh:mm")

		Timer {
			interval: 1000
			running: true
			repeat: true
			onTriggered: clockText.text = Qt.formatTime(new Date(), "hh:mm")
		}
	}

	// login box
	Rectangle {
		width: 380
		height: 220
		radius: 18
		color: "#00000000"
		anchors.centerIn: parent

		Column {
			anchors.horizontalCenter: parent.horizontalCenter
			anchors.verticalCenter: parent.verticalCenter
			anchors.verticalCenterOffset: 120
			spacing: 12

			TextField {
				id: userField
				horizontalAlignment: TextInput.AlignHCenter
				verticalAlignment: TextInput.AlignVCenter
				placeholderText: ""
				width: 300
				height: 45

				color: textColor
				font.pixelSize: 22
				font.bold: true
				font.family: "Funnel Sans"
				font.letterSpacing: 0.6

				background: Rectangle {
					radius: 10
					color: fieldBackgroundColor
					border.color: fieldBorderColor
					border.width: userField.activeFocus ? 2 : 0
					scale: userField.activeFocus ? 1.02 : 1.0
				}

				// placeholder text
				Text {
					anchors.centerIn: parent
					text: "Username"
					font.pixelSize: 18
					color: placeHolderTextColor
					visible: (userField.activeFocus == 0) && (userField.text.length === 0)
				}
			}

			TextField {
				id: passField
				horizontalAlignment: TextInput.AlignHCenter
				verticalAlignment: TextInput.AlignVCenter
				echoMode: TextInput.Password
				width: 300
				height: 45

				color: textColor
				font.pixelSize: 16
				font.letterSpacing: 0.8

				background: Rectangle {
					radius: 10
					color: fieldBackgroundColor
					border.color: fieldBorderColor
					border.width: passField.activeFocus ? 2 : 0
					scale: passField.activeFocus ? 1.02 : 1.0
				}

				// placeholder text
				Text {
					anchors.centerIn: parent
					text: "Password"
					font.pixelSize: 18
					color: placeHolderTextColor
					visible: (passField.activeFocus == 0) && (passField.text.length === 0)
				}

				onAccepted: {
					sddm.login(userField.text, passField.text, 0)
				}
			}
		}
	}
}
